@model StudentManagement.Models.Student

<h2>Delete Student</h2>

<p>Are you sure you want to delete this student?</p>

<table border="1" cellpadding="8">
    <tr><th>Name</th><td>@Model.Name</td></tr>
    <tr><th>Email</th><td>@Model.Email</td></tr>
    <tr><th>Department</th><td>@Model.DepartmentId</td></tr>
</table>

<br />

@using (Html.BeginForm("Delete", "Student", FormMethod.Post))  @* ← "Delete" not "DeleteConfirmed" *@
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.StudentId)    @* ← CRITICAL *@
    <input type="submit" value="Yes, Delete" style="color:red" />
}

<br />
@Html.ActionLink("← Cancel", "Index")
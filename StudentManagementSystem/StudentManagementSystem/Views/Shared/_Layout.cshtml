@using Microsoft.AspNetCore.Http

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduManage</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-sm navbar-light mb-4 sticky-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Account" asp-action="Login">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
                    <span>EduManage</span>
                </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-4">

                        @if (Context.Session.GetString("UserRole") == "Teacher")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="TeacherDashboard" asp-action="Index">Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Department" asp-action="Index">Departments</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Course" asp-action="Index">Courses</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Student" asp-action="Index">Students</a>
                            </li>
                        }
                        else if (Context.Session.GetString("UserRole") == "Student")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="StudentDashboard" asp-action="Index">My Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="StudentDashboard" asp-action="UpdateProfile">Edit Profile</a>
                            </li>
                        }

                    </ul>

                    <ul class="navbar-nav align-items-center">
                        @if (Context.Session.GetString("UserRole") != null)
                        {
                            <li class="nav-item">
                                <span class="nav-link user-greeting me-3">
                                    👋 @Context.Session.GetString("UserName")
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-outline-danger btn-sm px-3 rounded-pill" asp-controller="Account" asp-action="Logout">Logout</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-2">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Sign In</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary px-4 rounded-pill shadow-sm" asp-controller="Account" asp-action="Register">Create Account</a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="mt-5 py-4 text-center text-muted">
        <div class="container">
            <small>&copy; @DateTime.Now.Year - EduManage Student System. All rights reserved.</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
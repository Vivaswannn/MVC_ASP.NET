@{
    ViewData["Title"] = "Teacher Dashboard";
}

<h2>👨‍🏫 Welcome, @ViewBag.TeacherName!</h2>
<hr />

<div class="row mt-3">

    <div class="col-md-4">
        <div class="card text-white bg-primary shadow mb-4">
            <div class="card-body text-center">
                <h1 class="display-4">@ViewBag.TotalStudents</h1>
                <h5>Total Students</h5>
                <a class="btn btn-light btn-sm mt-2"
                       asp-controller="Student" asp-action="Index">
                    Manage Students →
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-white bg-success shadow mb-4">
            <div class="card-body text-center">
                <h1 class="display-4">@ViewBag.TotalCourses</h1>
                <h5>Total Courses</h5>
                <a class="btn btn-light btn-sm mt-2"
                       asp-controller="Course" asp-action="Index">
                    Manage Courses →
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-white bg-warning shadow mb-4">
            <div class="card-body text-center">
                <h1 class="display-4">@ViewBag.TotalDepartments</h1>
                <h5>Total Departments</h5>
                <a class="btn btn-light btn-sm mt-2"
                       asp-controller="Department" asp-action="Index">
                    Manage Departments →
                </a>
            </div>
        </div>
    </div>

</div>

<div class="row mt-2">
    <div class="col-md-4">
        <a asp-controller="Department" asp-action="Create" class="btn btn-outline-warning w-100 mb-2">➕ Add Department</a>
    </div>
    <div class="col-md-4">
        <a asp-controller="Course" asp-action="Create" class="btn btn-outline-success w-100 mb-2">➕ Add Course</a>
    </div>
    <div class="col-md-4">
        <a asp-controller="Student" asp-action="Create" class="btn btn-outline-primary w-100 mb-2">➕ Add Student</a>
    </div>
</div>
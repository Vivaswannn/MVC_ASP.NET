@{
    ViewData["Title"] = "Teacher Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0">👨‍🏫 Welcome, @ViewBag.TeacherName!</h3>
    <span class="badge bg-primary rounded-pill px-3 py-2 fw-medium shadow-sm">Teacher Access</span>
</div>

<div class="row g-4 mb-4">

    <div class="col-md-4">
        <div class="glass-card border-top border-primary border-4 text-center h-100 p-4">
            <h1 class="display-4 fw-bold text-primary mb-2">@ViewBag.TotalStudents</h1>
            <h6 class="text-muted fw-bold text-uppercase tracking-wide mb-3 small">Total Students</h6>
            <a class="btn btn-outline-primary btn-sm rounded-pill px-4 fw-medium"
                   asp-controller="Student" asp-action="Index">
                Manage Students →
            </a>
        </div>
    </div>

    <div class="col-md-4">
        <div class="glass-card border-top border-success border-4 text-center h-100 p-4">
            <h1 class="display-4 fw-bold text-success mb-2">@ViewBag.TotalCourses</h1>
            <h6 class="text-muted fw-bold text-uppercase tracking-wide mb-3 small">Total Courses</h6>
            <a class="btn btn-outline-success btn-sm rounded-pill px-4 fw-medium"
                   asp-controller="Course" asp-action="Index">
                Manage Courses →
            </a>
        </div>
    </div>

    <div class="col-md-4">
        <div class="glass-card border-top border-warning border-4 text-center h-100 p-4">
            <h1 class="display-4 fw-bold text-warning mb-2">@ViewBag.TotalDepartments</h1>
            <h6 class="text-muted fw-bold text-uppercase tracking-wide mb-3 small">Total Departments</h6>
            <a class="btn btn-outline-warning btn-sm rounded-pill px-4 fw-medium"
                   asp-controller="Department" asp-action="Index">
                Manage Departments →
            </a>
        </div>
    </div>

</div>

<div class="row g-4 mt-2">
    <div class="col-md-4">
        <a asp-controller="Department" asp-action="Create" class="glass-card text-decoration-none text-center d-block p-4 hover-lift">
            <span class="fs-2 d-block mb-2">🏢</span>
            <span class="fw-bold text-dark d-block">Add Department</span>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-controller="Course" asp-action="Create" class="glass-card text-decoration-none text-center d-block p-4 hover-lift">
            <span class="fs-2 d-block mb-2">📚</span>
            <span class="fw-bold text-dark d-block">Add Course</span>
        </a>
    </div>
    <div class="col-md-4">
        <a asp-controller="Student" asp-action="Create" class="glass-card text-decoration-none text-center d-block p-4 hover-lift">
            <span class="fs-2 d-block mb-2">🎓</span>
            <span class="fw-bold text-dark d-block">Add Student</span>
        </a>
    </div>
</div>
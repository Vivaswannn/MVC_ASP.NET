@model StudentManagementSystem.ViewModels.StudentProfileViewModel

@{
    ViewData["Title"] = "Student Dashboard";
}

<h2>🎓 Welcome, @Model.StudentName!</h2>
<hr />

<div class="row">

    <div class="col-md-6">
        <div class="card shadow mb-4">
            <div class="card-header bg-primary text-white">
                <h5>👤 My Profile</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Model.StudentName</dd>

                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>

                    <dt class="col-sm-4">Phone</dt>
                    <dd class="col-sm-8">@Model.PhoneNumber</dd>

                    <dt class="col-sm-4">Address</dt>
                    <dd class="col-sm-8">@Model.Address</dd>

                    <dt class="col-sm-4">Department</dt>
                    <dd class="col-sm-8">@Model.DepartmentName</dd>
                </dl>
                <a asp-action="UpdateProfile" class="btn btn-warning btn-sm mt-2">✏️ Edit Profile</a>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow mb-4">
            <div class="card-header bg-success text-white">
                <h5>📚 My Course Details</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Course</dt>
                    <dd class="col-sm-8">@Model.CourseName</dd>

                    <dt class="col-sm-4">Duration</dt>
                    <dd class="col-sm-8">@Model.CourseDuration weeks</dd>

                    <dt class="col-sm-4">Fees</dt>
                    <dd class="col-sm-8">Rs. @Model.CourseFees</dd>

                    <dt class="col-sm-4">Department</dt>
                    <dd class="col-sm-8">@Model.DepartmentName</dd>
                </dl>
            </div>
        </div>
    </div>

</div>
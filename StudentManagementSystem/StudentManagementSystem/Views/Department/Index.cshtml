@model IEnumerable<StudentManagementSystem.Models.Department>

@{
    ViewData["Title"] = "Departments";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>🏢 Departments</h2>
    <a asp-action="Create" class="btn btn-primary">➕ Add Department</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No departments found. Add one!</div>
}
else
{
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Department Name</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var dept in Model)
            {
                <tr>
                    <td>@dept.DepartmentId</td>
                    <td>@dept.DepartmentName</td>
                    <td>@dept.Description</td>
                    <td>
                        @Html.ActionLink("✏️ Edit", "Edit", new { id = dept.DepartmentId }, new { @class = "btn btn-sm btn-warning me-1" })
                        @Html.ActionLink("🗑 Delete", "Delete", new { id = dept.DepartmentId }, new { @class = "btn btn-sm btn-danger" })
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
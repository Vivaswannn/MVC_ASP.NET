@model IEnumerable<StudentManagementSystem.Models.Department>

@{
    ViewData["Title"] = "Departments";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-1">🏢 Departments</h3>
        <p class="text-muted small mb-0">Manage university departments</p>
    </div>
    <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm fw-medium">➕ Add Department</a>
</div>

<div class="glass-card shadow-sm">
    <div class="table-responsive">
        @if (!Model.Any())
        {
            <div class="p-5 text-center text-muted">
                <span class="fs-1 d-block mb-3">📭</span>
                <h5>No departments found</h5>
                <p>Get started by adding a new department.</p>
            </div>
        }
        else
        {
            <table class="table table-borderless table-hover mb-0">
                <thead class="bg-light bg-opacity-50">
                    <tr>
                        <th class="ps-4"># ID</th>
                        <th>Department Name</th>
                        <th>Description</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dept in Model)
                    {
                        <tr>
                            <td class="ps-4 text-muted fw-medium font-monospace">@dept.DepartmentId</td>
                            <td class="fw-bold text-dark">@dept.DepartmentName</td>
                            <td class="text-muted">@dept.Description</td>
                            <td class="text-end pe-4">
                                <a asp-action="Edit" asp-route-id="@dept.DepartmentId" class="btn btn-sm btn-light text-primary fw-medium rounded-pill px-3 me-2 border">Edit</a>
                                <a asp-action="Delete" asp-route-id="@dept.DepartmentId" class="btn btn-sm btn-light text-danger fw-medium rounded-pill px-3 border">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
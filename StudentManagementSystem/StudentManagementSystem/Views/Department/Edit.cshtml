@model StudentManagementSystem.Models.Department

@{
    ViewData["Title"] = "Edit Department";
}

<h2>✏️ Edit Department</h2>
<hr />

<div class="col-md-6">
    @using (Html.BeginForm("Edit", "Department", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.DepartmentId)

        <div class="mb-3">
            @Html.LabelFor(m => m.DepartmentName, new { @class = "form-label" })
            @Html.TextBoxFor(m => m.DepartmentName, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.DepartmentName, "", new { @class = "text-danger" })
        </div>

        <div class="mb-3">
            @Html.LabelFor(m => m.Description, new { @class = "form-label" })
            @Html.TextAreaFor(m => m.Description, new { @class = "form-control", rows = "3" })
            @Html.ValidationMessageFor(m => m.Description, "", new { @class = "text-danger" })
        </div>

        <button type="submit" class="btn btn-warning">Update</button>
        @Html.ActionLink("Cancel", "Index", null, new { @class = "btn btn-secondary ms-2" })
    }
</div>
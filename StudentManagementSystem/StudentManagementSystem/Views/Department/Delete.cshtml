@model StudentManagementSystem.Models.Department

@{
    ViewData["Title"] = "Delete Department";
}

<h2>🗑 Delete Department</h2>
<hr />

<div class="alert alert-danger">
    ⚠️ Are you sure you want to delete this department?
</div>

<dl class="row">
    <dt class="col-sm-3">Department Name</dt>
    <dd class="col-sm-9">@Model.DepartmentName</dd>

    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@Model.Description</dd>
</dl>

@using (Html.BeginForm("Delete", "Department", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.DepartmentId)
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    @Html.ActionLink("Cancel", "Index", null, new { @class = "btn btn-secondary ms-2" })
}
@model StudentManagementSystem.Models.Student

@{
    ViewData["Title"] = "Delete Student";
}

<h2>Delete Student</h2>
<hr />

<div class="alert alert-danger">
Are you sure you want to delete this student?
</div>

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.StudentName</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>

    <dt class="col-sm-3">Phone</dt>
    <dd class="col-sm-9">@Model.PhoneNumber</dd>

    <dt class="col-sm-3">Address</dt>
    <dd class="col-sm-9">@Model.Address</dd>
</dl>

@using (Html.BeginForm("Delete", "Student", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.StudentId)
<button type="submit" class="btn btn-danger">Yes, delete</button>
@Html.ActionLink("Cancel", "Index", null, new { @class = "btn btn-secondary ms-2" })
}
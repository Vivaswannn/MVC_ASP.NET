@model IEnumerable<StudentManagementSystem.Models.Student>

@{
    ViewData["Title"] = "Students Roster";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-1">🎓 Student Roster</h3>
        <p class="text-muted small mb-0">Search and manage enrolled students</p>
    </div>
    <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm fw-medium">➕ Register Student</a>
</div>

<div class="glass-card mb-4 p-3 bg-white bg-opacity-50 shadow-sm border-0">
    <form asp-controller="Student" asp-action="Search" method="get" class="row g-2 align-items-end">
        <div class="col-md-5">
            <label class="form-label text-muted small fw-bold text-uppercase mb-1 tracking-wide">Search by Name</label>
            <input type="text" name="name" class="form-control bg-white shadow-sm border border-light"
                   placeholder="Enter student name..."
                   value="@ViewBag.SearchName" />
        </div>
        <div class="col-md-4">
            <label class="form-label text-muted small fw-bold text-uppercase mb-1 tracking-wide">Filter Department</label>
            <select name="departmentId" class="form-select bg-white shadow-sm border border-light">
                <option value="">All Departments</option>
                @if (ViewBag.Departments != null)
                {
                    foreach (var dept in (List<StudentManagementSystem.Models.Department>)ViewBag.Departments)
                    {
                        <option value="@dept.DepartmentId" selected="@(ViewBag.SelectedDepartment != null && (int)ViewBag.SelectedDepartment == dept.DepartmentId ? "selected" : null)">
                            @dept.DepartmentName
                        </option>
                    }
                }
            </select>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-primary flex-grow-1 shadow-sm fw-bold">Search</button>
            <a asp-action="Index" class="btn btn-light border flex-grow-1 fw-bold text-muted">Clear</a>
        </div>
    </form>
</div>

<div class="glass-card shadow-sm">
    <div class="table-responsive">
        @if (!Model.Any())
        {
            <div class="p-5 text-center text-muted">
                <span class="fs-1 d-block mb-3">📭</span>
                <h5>No students found</h5>
                <p>Try adjusting your search or add a new student.</p>
            </div>
        }
        else
        {
            <table class="table table-borderless table-hover mb-0">
                <thead class="bg-light bg-opacity-50">
                    <tr>
                        <th class="ps-4">Student Name</th>
                        <th>Contact Info</th>
                        <th>Enrollment</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-dark align-middle">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="bg-primary bg-gradient bg-opacity-10 text-primary fs-5 fw-bold rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width:44px;height:44px;">
                                        @student.StudentName.Substring(0, 1).ToUpper()
                                    </div>
                                    @student.StudentName
                                </div>
                            </td>
                            <td class="align-middle text-muted small">
                                <div class="mb-1 text-dark fw-medium">📧 @student.Email</div>
                                <div>📱 @student.PhoneNumber</div>
                            </td>
                            <td class="align-middle">
                                <div class="mb-1"><span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-2 py-1">@student.Course.CourseName</span></div>
                                <div><span class="badge bg-light text-muted border rounded-pill px-2 py-1">@student.Department.DepartmentName</span></div>
                            </td>
                            <td class="text-end pe-4 align-middle">
                                <a asp-action="Edit" asp-route-id="@student.StudentId" class="btn btn-sm btn-light text-primary fw-medium rounded-pill px-3 me-2 border">Edit</a>
                                <a asp-action="Delete" asp-route-id="@student.StudentId" class="btn btn-sm btn-light text-danger fw-medium rounded-pill px-3 border">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
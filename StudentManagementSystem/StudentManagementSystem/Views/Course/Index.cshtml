@model IEnumerable<StudentManagementSystem.Models.Course>

@{
    ViewData["Title"] = "Courses";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-1">📚 Courses</h3>
        <p class="text-muted small mb-0">Manage available curriculums</p>
    </div>
    <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm fw-medium">➕ Add Course</a>
</div>

<div class="glass-card shadow-sm">
    <div class="table-responsive">
        @if (!Model.Any())
        {
            <div class="p-5 text-center text-muted">
                <span class="fs-1 d-block mb-3">📭</span>
                <h5>No courses found</h5>
                <p>Get started by adding a new course.</p>
            </div>
        }
        else
        {
            <table class="table table-borderless table-hover mb-0">
                <thead class="bg-light bg-opacity-50">
                    <tr>
                        <th class="ps-4">Course Name</th>
                        <th>Duration</th>
                        <th>Fees</th>
                        <th>Department</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-dark">@course.CourseName</td>
                            <td class="text-muted"><span class="badge bg-light text-dark border px-2 py-1">@course.Duration weeks</span></td>
                            <td class="font-monospace text-success fw-bold">Rs. @course.Fees</td>
                            <td><span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-2 py-1">@course.Department.DepartmentName</span></td>
                            <td class="text-end pe-4">
                                <a asp-action="Edit" asp-route-id="@course.CourseId" class="btn btn-sm btn-light text-primary fw-medium rounded-pill px-3 me-2 border">Edit</a>
                                <a asp-action="Delete" asp-route-id="@course.CourseId" class="btn btn-sm btn-light text-danger fw-medium rounded-pill px-3 border">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
@model IEnumerable<StudentManagementSystem.Models.Course>

@{
    ViewData["Title"] = "Courses";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📚 Courses</h2>
    <a asp-action="Create" class="btn btn-primary">➕ Add Course</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No courses found. Add one!</div>
}
else
{
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Course Name</th>
                <th>Duration (weeks)</th>
                <th>Fees</th>
                <th>Department</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var course in Model)
            {
                <tr>
                    <td>@course.CourseId</td>
                    <td>@course.CourseName</td>
                    <td>@course.Duration</td>
                    <td>Rs. @course.Fees</td>
                    <td>@course.Department.DepartmentName</td>
                    <td>
                        @Html.ActionLink("✏️ Edit", "Edit", new { id = course.CourseId }, new { @class = "btn btn-sm btn-warning me-1" })
                        @Html.ActionLink("🗑 Delete", "Delete", new { id = course.CourseId }, new { @class = "btn btn-sm btn-danger" })
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
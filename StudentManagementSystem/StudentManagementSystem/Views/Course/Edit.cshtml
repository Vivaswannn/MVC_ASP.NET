@model StudentManagementSystem.Models.Course

@{
    ViewData["Title"] = "Edit Course";
}

<h2>✏️ Edit Course</h2>
<hr />

<div class="col-md-6">
    @using (Html.BeginForm("Edit", "Course", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.CourseId)

        <div class="mb-3">
            @Html.LabelFor(m => m.CourseName, new { @class = "form-label" })
            @Html.TextBoxFor(m => m.CourseName, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.CourseName, "", new { @class = "text-danger" })
        </div>

        <div class="mb-3">
            @Html.LabelFor(m => m.Duration, new { @class = "form-label" })
            @Html.TextBoxFor(m => m.Duration, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.Duration, "", new { @class = "text-danger" })
        </div>

        <div class="mb-3">
            @Html.LabelFor(m => m.Fees, new { @class = "form-label" })
            @Html.TextBoxFor(m => m.Fees, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.Fees, "", new { @class = "text-danger" })
        </div>

        <div class="mb-3">
            <label class="form-label">Department</label>
            @Html.DropDownListFor(m => m.DepartmentId,
                new SelectList(ViewBag.Departments, "DepartmentId", "DepartmentName"),
                new { @class = "form-select" })
        </div>

        <button type="submit" class="btn btn-warning">Update</button>
        @Html.ActionLink("Cancel", "Index", null, new { @class = "btn btn-secondary ms-2" })
    }
</div>
@model StudentManagementSystem.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Create Account";
}

<div class="row justify-content-center my-4">
    <div class="col-md-8 col-lg-7">
        <div class="glass-card border-0 shadow">
            
            <div class="glass-header text-center pb-2 border-0">
                <div class="bg-primary bg-gradient text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3 mt-2 shadow-sm" style="width: 56px; height: 56px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                </div>
                <h4 class="fw-bold mb-1">Join EduManage</h4>
                <p class="text-muted small mb-0">Discover exceptional student & teacher management.</p>
            </div>

            <div class="glass-body pt-0">
                @using (Html.BeginForm("Register", "Account", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    <div class="row g-3">
                        <div class="col-md-6">
                            @Html.LabelFor(m => m.FullName, new { @class = "form-label fw-medium text-muted small" })
                            @Html.TextBoxFor(m => m.FullName, new { @class = "form-control bg-light", placeholder="John Doe" })
                            @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-md-6">
                            @Html.LabelFor(m => m.Email, new { @class = "form-label fw-medium text-muted small" })
                            @Html.TextBoxFor(m => m.Email, new { @class = "form-control bg-light", placeholder="name@example.com" })
                            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-md-6">
                            @Html.LabelFor(m => m.Password, new { @class = "form-label fw-medium text-muted small" })
                            @Html.PasswordFor(m => m.Password, new { @class = "form-control bg-light", placeholder="••••••••" })
                            @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-md-6">
                            @Html.LabelFor(m => m.ConfirmPassword, new { @class = "form-label fw-medium text-muted small" })
                            @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control bg-light", placeholder="••••••••" })
                            @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-bold text-primary small text-uppercase tracking-wide mb-2 mt-2">Account Role</label>
                            @Html.DropDownListFor(m => m.Role,
                                new SelectList(new[] { "Student", "Teacher" }),
                                "-- Select Role --",
                                new { @class = "form-select fw-medium border-primary shadow-sm" })
                            @Html.ValidationMessageFor(m => m.Role, "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-12 mt-4 text-center">
                            <span class="badge bg-secondary px-3 py-2 rounded-pill fw-medium tracking-wide">STUDENT ONLY INFO</span>
                        </div>

                        <div class="col-md-6">
                            @Html.LabelFor(m => m.PhoneNumber, new { @class = "form-label fw-medium text-muted small" })
                            @Html.TextBoxFor(m => m.PhoneNumber, new { @class = "form-control bg-light", placeholder="Phone #" })
                            @Html.ValidationMessageFor(m => m.PhoneNumber, "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-medium text-muted small">Department</label>
                            @Html.DropDownListFor(m => m.DepartmentId,
                                new SelectList(ViewBag.Departments, "DepartmentId", "DepartmentName"),
                                "-- Ignore if Teacher --",
                                new { @class = "form-select bg-light" })
                            @Html.ValidationMessageFor(m => m.DepartmentId, "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-medium text-muted small">Course</label>
                            @Html.DropDownListFor(m => m.CourseId,
                                new SelectList(ViewBag.Courses, "CourseId", "CourseName"),
                                "-- Ignore if Teacher --",
                                new { @class = "form-select bg-light" })
                            @Html.ValidationMessageFor(m => m.CourseId, "", new { @class = "text-danger small" })
                        </div>

                        <div class="col-md-6">
                            @Html.LabelFor(m => m.Address, new { @class = "form-label fw-medium text-muted small" })
                            @Html.TextAreaFor(m => m.Address, new { @class = "form-control bg-light", rows = "1", placeholder="Address" })
                            @Html.ValidationMessageFor(m => m.Address, "", new { @class = "text-danger small" })
                        </div>

                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 mt-4 mb-2 fw-bold shadow-sm">Create Account</button>
                }

                <div class="text-center mt-3 pt-3 border-top">
                    <p class="text-muted small mb-0">
                        Already have an account? <a href="/Account/Login" class="text-primary fw-medium text-decoration-none">Sign in here</a>
                    </p>
                </div>

            </div>
        </div>
    </div>
</div>
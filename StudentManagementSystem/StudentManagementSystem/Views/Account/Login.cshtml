@model StudentManagementSystem.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Welcome Back";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5 col-lg-4">
        <div class="glass-card border-0 text-center shadow">
            
            <div class="p-4 pb-2">
                <div class="bg-primary bg-gradient text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 60px; height: 60px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                </div>
                <h4 class="fw-bold mb-1">Welcome Back</h4>
                <p class="text-muted small">Please sign in to your accounts</p>
            </div>

            <div class="glass-body text-start pt-2">
                @Html.ValidationSummary(false, "", new { @class = "text-danger small mb-3 fw-medium" })

                @using (Html.BeginForm("Login", "Account", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        @Html.LabelFor(m => m.Email, new { @class = "form-label fw-medium text-muted small" })
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "name@example.com" })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                    </div>

                    <div class="mb-4">
                        @Html.LabelFor(m => m.Password, new { @class = "form-label fw-medium text-muted small" })
                        @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "••••••••" })
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 mb-3 fw-bold shadow-sm">Sign In</button>
                }

                <div class="text-center mt-4 pt-2 border-top">
                    <p class="text-muted small mb-0 mt-3">
                        Don't have an account? <br/>
                        <a href="/Account/Register" class="text-primary fw-medium text-decoration-none">Create one now</a>
                    </p>
                </div>

            </div>
        </div>
    </div>
</div>
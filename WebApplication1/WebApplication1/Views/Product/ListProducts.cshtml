@{
}


<h2>ListProducts</h2>

<table border="1">
    <tr>
        <td> ProductCode</td>
        <td> ProductName</td>
        <td> Fees</td>
    </tr>

    @foreach (var item in ViewBag.Products)
    {
        <tr>
            <td>@item.ProductCode</td>
            <td>@item.ProductName</td>
            <td>@item.Fees</td>
        </tr>
}

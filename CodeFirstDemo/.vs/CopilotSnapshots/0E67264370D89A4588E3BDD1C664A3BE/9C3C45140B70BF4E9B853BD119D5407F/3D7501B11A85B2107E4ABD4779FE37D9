@model IEnumerable<CodeFirstDemo.Models.Employee>
@{
    ViewData["Title"] = "Employee List";
}
<h2>Employee List</h2>
<p>@Html.ActionLink("Create New Employee", "Create")</p>
<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.EmpName)</th>

            <th>@Html.DisplayNameFor(model => model.Address)</th>

            <th>@Html.DisplayNameFor(model => model.Salary)</th>

            <th>@Html.DisplayNameFor(model => model.Email)</th>

            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.EmpName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Address)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Salary)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Email)
                </td>
                <td>
                    @Html.ActionLink("Edit", "Edit", new { id = item.EmpID }, new { @class = "btn btn-sm btn-primary me-1" })
                    @Html.ActionLink("Details", "Details", new { id = item.EmpID }, new { @class = "btn btn-sm btn-secondary me-1" })
                    @using (Html.BeginForm("Delete", "Employee", FormMethod.Post, new { @class = "d-inline" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.Hidden("id", item.EmpID)
                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this employee?');">Delete</button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
